{% extends 'base.html.twig' %}
{% block title %}Guichet Kbadha{% endblock %}

{% block body %}

{# ── En-tête ─────────────────────────────────────────────────────── #}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-cash-register mr-2 text-success"></i>
        Tableau de Bord Guichet
    </h1>
    <ol class="breadcrumb mb-0 bg-transparent">
        <li class="breadcrumb-item"><a href="{{ path('kbadha_dashboard') }}">Accueil</a></li>
        <li class="breadcrumb-item active">Dashboard</li>
    </ol>
</div>
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <p class="text-muted mb-0 small">
        <i class="fas fa-calendar-day mr-1"></i>{{ "now"|date("d/m/Y") }} &nbsp;|&nbsp;
        <i class="fas fa-clock mr-1"></i>{{ "now"|date("H:i") }}
    </p>
    <a href="{{ path('kbadha_citoyen_recherche') }}" class="btn btn-success btn-sm shadow">
        <i class="fas fa-search mr-1"></i>Accueillir un Citoyen
    </a>
</div>

{# ── 4 Cartes KPI ─────────────────────────────────────────────────── #}
<div class="row mb-4">

    {# Paiements aujourd'hui #}
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Paiements aujourd'hui</div>
                        <div class="mb-0 text-gray-800">
                            <span class="h2 font-weight-bold">{{ nbPaiementsAujourdhui }}</span>
                        </div>
                        <div class="progress progress-sm mt-2">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: 25%" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                    <div class="col-auto"><i class="fas fa-hand-holding-usd fa-2x text-gray-300"></i></div>
                </div>
            </div>
        </div>
    </div>

    {# Encaissé aujourd'hui #}
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Encaissé aujourd'hui</div>
                        <div class="mb-0 text-gray-800">
                            <span class="h2 font-weight-bold">{{ totalAujourdhui }}</span> <small>DT</small>
                        </div>
                        <div class="progress progress-sm mt-2">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 40%" aria-valuenow="40" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                    <div class="col-auto"><i class="fas fa-cash-register fa-2x text-gray-300"></i></div>
                </div>
            </div>
        </div>
    </div>

    {# Paiements ce mois #}
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-info shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Paiements ce mois</div>
                        <div class="mb-0 text-gray-800">
                            <span class="h2 font-weight-bold">{{ nbPaiementsMois }}</span>
                        </div>
                        <div class="progress progress-sm mt-2">
                            <div class="progress-bar bg-info" role="progressbar" style="width: 70%" aria-valuenow="70" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                    <div class="col-auto"><i class="fas fa-chart-line fa-2x text-gray-300"></i></div>
                </div>
            </div>
        </div>
    </div>

    {# Encaissé ce mois #}
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Encaissé ce mois</div>
                        <div class="mb-0 text-gray-800">
                            <span class="h2 font-weight-bold">{{ totalMois }}</span> <small>DT</small>
                        </div>
                        <div class="progress progress-sm mt-2">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 90%" aria-valuenow="90" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                    <div class="col-auto"><i class="fas fa-receipt fa-2x text-gray-300"></i></div>
                </div>
            </div>
        </div>
    </div>

</div>

{# ── Bouton d'action principale ────────────────────────────────────── #}
<div class="row mb-4">
    <div class="col-12 text-center">
        <a href="{{ path('kbadha_citoyen_recherche') }}" class="btn btn-primary btn-lg px-5 py-3 shadow">
            <i class="fas fa-search fa-2x mb-1 d-block"></i>
            Accueillir un Citoyen
        </a>
        <p class="text-muted small mt-2">
            <i class="fas fa-id-card mr-1"></i>
            Scannez ou saisissez le CIN du citoyen pour accéder à son dossier
        </p>
    </div>
</div>

{# ── Tableau des derniers encaissements ────────────────────────────── #}
<div class="row">
    <div class="col-12">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-success">
                    <i class="fas fa-history mr-2"></i>Derniers encaissements
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover table-sm mb-0">
                        <thead class="thead-dark">
                            <tr>
                                <th class="text-center">Référence</th>
                                <th>Citoyen (CIN)</th>
                                <th>Objet</th>
                                <th class="text-right">Montant</th>
                                <th class="text-center">Mode</th>
                                <th>Heure</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% if derniersPaiements is empty %}
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">
                                        <i class="fas fa-inbox fa-2x d-block mb-2 text-gray-300"></i>
                                        Aucun encaissement pour le moment.
                                    </td>
                                </tr>
                            {% else %}
                                {% for p in derniersPaiements %}
                                    <tr>
                                        <td class="text-center">
                                            <span class="badge badge-secondary px-3 py-1 font-weight-normal">{{ p.reference }}</span>
                                        </td>
                                        <td class="font-weight-bold small">{{ p.user ? p.user.cin : '—' }}</td>
                                        <td class="small text-muted">{{ p.sujet|slice(0,40) }}</td>
                                        <td class="text-right"><span class="text-success font-weight-bold">{{ p.montant }} DT</span></td>
                                        <td class="text-center">
                                            {% if p.modePaiement == 'especes' %}
                                                <span class="badge badge-secondary px-3 py-1">Espèces</span>
                                            {% elseif p.modePaiement == 'cheque' %}
                                                <span class="badge badge-dark px-3 py-1">Chèque</span>
                                            {% else %}
                                                <span class="badge badge-secondary px-3 py-1">{{ p.modePaiement }}</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-muted small">
                                            {{ p.datePaiement ? p.datePaiement|date('H:i') : '—' }}
                                        </td>
                                        <td class="text-center">
                                            <a href="{{ path('kbadha_recu', {id: p.id}) }}"
                                               class="btn btn-info btn-sm mr-1" title="Consulter le reçu">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}

<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="kbadhapay – Réinitialisation de mot de passe">
    <meta name="author" content="Recouvrement financier de Tunis">

    <title>kbadhapay – Mot de passe oublié</title>

    <!-- Custom fonts -->
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <!-- SB Admin 2 CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/startbootstrap-sb-admin-2/4.1.4/css/sb-admin-2.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

    <style>
        .brand-title { font-size: 2rem; font-weight: 800; color: #4e73df; letter-spacing: -0.5px; }
        .brand-subtitle { font-size: 0.85rem; color: #6c757d; letter-spacing: 0.5px; text-transform: uppercase; font-weight: 600; }
        .brand-icon { font-size: 2.5rem; color: #4e73df; margin-bottom: 0.25rem; }

    </style>
</head>

<body class="bg-gradient-primary">

    <div class="container">
        <!-- Outer Row -->
        <div class="row justify-content-center">
            <div class="col-xl-10 col-lg-12 col-md-9">
                <div class="card o-hidden border-0 shadow-lg my-5">
                    <div class="card-body p-0">
                        <!-- Nested Row within Card Body -->
                        <div class="row">
                            <div class="col-lg-6">
                                <div class="p-5">
                                    <div class="text-center mb-4">
                                        <div class="brand-icon"><i class="fas fa-landmark"></i></div>
                                        <h1 class="brand-title">kbadhapay</h1>
                                        <p class="brand-subtitle">Récupération de compte</p>
                                    </div>

                                    <div class="text-center">
                                        <h1 class="h4 text-gray-900 mb-2">Mot de passe oublié ?</h1>
                                        <p class="mb-4">Pas de panique ! Entrez votre adresse e-mail ci-dessous et nous vous enverrons un lien pour réinitialiser votre mot de passe.</p>
                                    </div>

                                    {% for flash_error in app.flashes('reset_password_error') %}
                                        <div class="alert alert-danger" role="alert">
                                            <i class="fas fa-exclamation-triangle mr-2"></i>{{ flash_error }}
                                        </div>
                                    {% endfor %}

                                    {{ form_start(requestForm, {'attr': {'class': 'user'}}) }}
                                        <div class="form-group">
                                            {{ form_label(requestForm.email, 'Adresse Email', {'label_attr': {'class': 'small font-weight-bold text-gray-700'}}) }}
                                            {{ form_widget(requestForm.email, {
                                                'attr': {
                                                    'class': 'form-control form-control-user',
                                                    'placeholder': 'Entrez votre adresse email...',
                                                    'autocomplete': 'email'
                                                }
                                            }) }}
                                            <div class="text-danger small mt-1">
                                                {{ form_errors(requestForm.email) }}
                                            </div>
                                        </div>
                                        <button type="submit" class="btn btn-primary btn-user btn-block">
                                            Réinitialiser le mot de passe
                                        </button>
                                    {{ form_end(requestForm) }}

                                    <hr>
                                    <div class="text-center">
                                        <a class="small" href="{{ path('app_login') }}">Déjà un compte ? Connectez-vous !</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

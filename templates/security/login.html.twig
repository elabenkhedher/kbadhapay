<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="kbadhapay – Plateforme municipale de paiement de taxes et amendes – Recouvrement financier de Tunis">
    <meta name="author" content="Recouvrement financier de Tunis">

    <title>kbadhapay – Connexion | Recouvrement financier de Tunis</title>

    <!-- Custom fonts for this template -->
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">

    <!-- Custom styles for this template -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/startbootstrap-sb-admin-2/4.1.4/css/sb-admin-2.min.css" rel="stylesheet">

    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

    <style>
        /* Surcharge légère pour renforcer le branding kbadhapay */
        .brand-title {
            font-size: 2rem;
            font-weight: 800;
            color: #4e73df;
            letter-spacing: -0.5px;
        }
        .brand-subtitle {
            font-size: 0.85rem;
            color: #6c757d;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            font-weight: 600;
        }
        .brand-icon {
            font-size: 2.5rem;
            color: #4e73df;
            margin-bottom: 0.25rem;
        }
        .bg-login-image {
            background: url('https://source.unsplash.com/K4mSJ7kc0As/600x800') center center no-repeat;
            background-size: cover;
        }
        .card-body {
            padding: 2.5rem;
        }
        /* Responsive fix for the left image panel */
        @media (max-width: 767.98px) {
            .col-lg-6.d-none {
                display: none !important;
            }
        }
    </style>
</head>

<body class="bg-gradient-primary">

    <div class="container">

        <!-- Outer Row -->
        <div class="row justify-content-center">

            <div class="col-xl-10 col-lg-12 col-md-9">

                <div class="card o-hidden border-0 shadow-lg my-5">
                    <div class="card-body p-0">
                        <!-- Nested Row within Card Body -->
                        <div class="row">

                            <!-- Panneau image gauche -->
                            <div class="col-lg-6 d-none d-lg-block bg-login-image"></div>

                            <!-- Panneau formulaire droite -->
                            <div class="col-lg-6">
                                <div class="p-5">

                                    <!-- ── BRANDING ── -->
                                    <div class="text-center mb-4">
                                        <div class="brand-icon">
                                            <i class="fas fa-landmark"></i>
                                        </div>
                                        <h1 class="brand-title">kbadhapay</h1>
                                        <p class="brand-subtitle">Recouvrement financier de Tunis</p>
                                    </div>

                                    <h2 class="h4 text-gray-900 mb-4 text-center">Bienvenue !</h2>

                                    <!-- ── MESSAGES D'ERREUR SYMFONY ── -->
                                    {% if error %}
                                        <div class="alert alert-danger" role="alert">
                                            <i class="fas fa-exclamation-circle mr-1"></i>
                                            {{ error.messageKey | trans(error.messageData, 'security') }}
                                        </div>
                                    {% endif %}

                                    <!-- ── FORMULAIRE DE CONNEXION ── -->
                                    <form class="user" action="{{ path('app_login') }}" method="POST">

                                        <!-- Champ CIN -->
                                        <div class="form-group">
                                            <label for="cin" class="text-gray-700 font-weight-bold small">
                                                Numéro CIN
                                            </label>
                                            <input
                                                type="text"
                                                class="form-control form-control-user"
                                                id="cin"
                                                name="_username"
                                                placeholder="Entrez votre CIN (8 chiffres)"
                                                pattern="[0-9]{8}"
                                                maxlength="8"
                                                inputmode="numeric"
                                                autocomplete="username"
                                                required
                                                value="{{ last_username }}"
                                            >
                                        </div>

                                        <!-- Champ Mot de passe -->
                                        <div class="form-group">
                                            <label for="password" class="text-gray-700 font-weight-bold small">
                                                Mot de passe
                                            </label>
                                            <input
                                                type="password"
                                                class="form-control form-control-user"
                                                id="password"
                                                name="_password"
                                                placeholder="Mot de passe"
                                                autocomplete="current-password"
                                                required
                                            >
                                        </div>

                                        <!-- Se souvenir de moi -->
                                        <div class="form-group">
                                            <div class="custom-control custom-checkbox small">
                                                <input
                                                    type="checkbox"
                                                    class="custom-control-input"
                                                    id="rememberMe"
                                                    name="_remember_me"
                                                >
                                                <label class="custom-control-label" for="rememberMe">
                                                    Se souvenir de moi
                                                </label>
                                            </div>
                                        </div>

                                        <!-- Token CSRF Symfony (obligatoire) -->
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                                        <!-- Bouton de connexion -->
                                        <button type="submit" class="btn btn-primary btn-user btn-block">
                                            <i class="fas fa-sign-in-alt mr-1"></i>
                                            Se Connecter
                                        </button>

                                    </form>
                                    <!-- ── FIN FORMULAIRE ── -->

                                    <hr>
                                    <div class="text-center">
                                        <a class="small" href="{{ path('app_forgot_password_request') }}">
                                            <i class="fas fa-key mr-1"></i>
                                            Mot de passe oublié ?
                                        </a>
                                    </div>

                                </div>
                            </div>
                            <!-- ── FIN panneau formulaire ── -->

                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>

    <!-- Bootstrap core JavaScript -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Core plugin JavaScript -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-easing/1.4.1/jquery.easing.min.js"></script>

    <!-- Custom scripts for all pages -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/startbootstrap-sb-admin-2/4.1.4/js/sb-admin-2.min.js"></script>

</body>

</html>

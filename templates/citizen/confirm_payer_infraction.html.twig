{% extends 'base.html.twig' %}

{% block title %}Confirmer le Paiement — kbadhapay{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-warning text-dark text-center py-4">
                    <h3 class="font-weight-light my-2">
                        <i class="fas fa-credit-card mr-2"></i>Confirmation de Paiement
                    </h3>
                </div>
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="display-4 font-weight-bold text-warning mb-2">
                            {{ infraction.montantTotal|number_format(3, ',', ' ') }} <small>DT</small>
                        </div>
                        <p class="text-muted">Règlement de votre infraction #{{ infraction.id }}</p>
                    </div>

                    <div class="bg-light p-4 rounded-lg mb-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Type :</span>
                            <span class="font-weight-bold">{{ infraction.typeInfraction|replace({'_': ' '})|title }}</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Lieu :</span>
                            <span class="font-weight-bold">{{ infraction.lieu }}</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Date :</span>
                            <span class="font-weight-bold">{{ infraction.dateInfraction|date('d/m/Y') }}</span>
                        </div>
                        {% if infraction.penalite > 0 %}
                            <div class="d-flex justify-content-between text-danger">
                                <span>Pénalité de retard :</span>
                                <span>+ {{ infraction.penalite|number_format(3, ',', ' ') }} DT</span>
                            </div>
                        {% endif %}
                    </div>

                    <form action="{{ path('citizen_payer_infraction', {id: infraction.id}) }}" method="POST">
                        <input type="hidden" name="_token" value="{{ csrf_token('payer_infraction_' ~ infraction.id) }}">
                        
                        <div class="alert alert-info small mb-4">
                            <i class="fas fa-info-circle mr-2"></i>
                            En cliquant sur le bouton ci-dessous, vous serez débité du montant indiqué via votre mode de paiement sécurisé.
                        </div>

                        <button type="submit" class="btn btn-warning btn-block btn-lg shadow-sm font-weight-bold text-dark py-3">
                            <i class="fas fa-lock mr-2"></i>Confirmer et Payer maintenant
                        </button>
                        
                        <a href="{{ path('citizen_dashboard') }}" class="btn btn-link btn-block text-muted mt-2">
                            Annuler et revenir au tableau de bord
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card { transition: transform 0.3s; }
    .btn-warning:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(246, 194, 62, 0.4) !important; }
</style>
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}Mes Infractions — kbadhapay{% endblock %}

{% block body %}

<div class="d-sm-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-exclamation-triangle mr-2 text-warning"></i>Mes Infractions
    </h1>
</div>

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-white shadow-sm small">
        <li class="breadcrumb-item"><a href="{{ path('citizen_dashboard') }}"><i class="fas fa-home mr-1"></i>Accueil</a></li>
        <li class="breadcrumb-item active">Mes Infractions</li>
    </ol>
</nav>

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-warning">
            <i class="fas fa-table mr-2"></i>Historique de mes infractions
            <span class="badge badge-warning ml-1">{{ infractions|length }}</span>
        </h6>
    </div>
    <div class="card-body">
        {% if infractions is empty %}
            <div class="alert alert-success mb-0">
                <i class="fas fa-check-circle mr-2"></i>
                Aucune infraction enregistrée sur votre dossier. Continuez comme ça !
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover table-bordered table-sm">
                    <thead class="thead-light">
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Lieu</th>
                            <th>Échéance</th>
                            <th class="text-right">Montant</th>
                            <th class="text-center">Statut</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for i in infractions %}
                            <tr>
                                <td>{{ i.dateInfraction|date('d/m/Y H:i') }}</td>
                                <td class="font-weight-bold">{{ i.typeInfraction|replace({'_': ' '})|title }}</td>
                                <td>{{ i.lieu }}</td>
                                <td>
                                    {% if i.dateEcheance %}
                                        {% set diff = (date().timestamp - i.dateEcheance.timestamp) / 86400 %}
                                        <span class="{% if i.statut == 'a_payer' and diff > 0 %}text-danger font-weight-bold{% endif %}">
                                            {{ i.dateEcheance|date('d/m/Y') }}
                                        </span>
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td class="text-right">
                                    <span class="font-weight-bold">{{ i.montantTotal|number_format(3, ',', ' ') }} DT</span>
                                    {% if i.statut == 'a_payer' and i.penalite > 0 %}
                                        <br><small class="text-danger">+ {{ i.penalite|number_format(3, ',', ' ') }} DT (retard)</small>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    {% if i.statut == 'a_payer' %}
                                        <span class="badge badge-warning text-dark px-2 py-1"><i class="fas fa-clock mr-1"></i>À Payer</span>
                                    {% elseif i.statut == 'paye' %}
                                        <span class="badge badge-success px-2 py-1"><i class="fas fa-check mr-1"></i>Réglée</span>
                                    {% elseif i.statut == 'conteste' %}
                                        <span class="badge badge-warning text-dark px-2 py-1"><i class="fas fa-gavel mr-1"></i>Contestée</span>
                                    {% else %}
                                        <span class="badge badge-secondary px-2 py-1">{{ i.statut }}</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    {% if i.statut == 'a_payer' %}
                                        <form action="{{ path('citizen_payer_infraction', {id: i.id}) }}"
                                              method="POST"
                                              onsubmit="return confirm('Confirmer le paiement de l\'amende ({{ i.montantAmende }} DT) ?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('payer_infraction_' ~ i.id) }}">
                                            <button type="submit" class="btn btn-warning btn-sm text-dark">
                                                <i class="fas fa-credit-card mr-1"></i>Payer
                                            </button>
                                        </form>
                                    {% else %}
                                        <span class="text-muted small">—</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>

{% endblock %}

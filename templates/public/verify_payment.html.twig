{% extends 'base.html.twig' %}

{% block title %}Vérification du Paiement — kbadhapay{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-primary text-white text-center py-3">
                <h4 class="mb-0"><i class="fas fa-shield-alt mr-2"></i>Vérification d'Authenticité</h4>
            </div>
            <div class="card-body text-center py-5">
                {% if paiement %}
                    <div class="mb-4">
                        <i class="fas fa-check-circle fa-5x text-success mb-3"></i>
                        <h3 class="text-success font-weight-bold">Paiement Vérifié</h3>
                        <p class="text-muted">Ce paiement est enregistré officiellement dans notre système.</p>
                    </div>

                    <hr>

                    <div class="text-left mt-4 px-4">
                        <div class="row mb-2">
                            <div class="col-5 font-weight-bold text-gray-800">Référence :</div>
                            <div class="col-7">{{ paiement.reference }}</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-5 font-weight-bold text-gray-800">Citoyen :</div>
                            <div class="col-7">{{ paiement.user.nom ?? paiement.user.cin }}</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-5 font-weight-bold text-gray-800">Montant :</div>
                            <div class="col-7 font-weight-bold">{{ paiement.montant|number_format(3, ',', ' ') }} DT</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-5 font-weight-bold text-gray-800">Date :</div>
                            <div class="col-7">{{ paiement.datePaiement|date('d/m/Y H:i') }}</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-5 font-weight-bold text-gray-800">Statut :</div>
                            <div class="col-7">
                                <span class="badge badge-success px-3 py-1">Payé</span>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="mb-4">
                        <i class="fas fa-times-circle fa-5x text-danger mb-3"></i>
                        <h3 class="text-danger font-weight-bold">Paiement Non Trouvé</h3>
                        <p class="text-muted">La référence <strong>{{ reference }}</strong> ne correspond à aucun paiement valide.</p>
                    </div>
                    <a href="/" class="btn btn-primary mt-3">Retour à l'accueil</a>
                {% endif %}
            </div>
            <div class="card-footer bg-light text-center small text-muted">
                kbadhapay — Recouvrement financier de Tunis — © {{ "now"|date("Y") }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

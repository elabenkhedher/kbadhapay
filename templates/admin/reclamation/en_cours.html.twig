{% extends 'base.html.twig' %}

{% block title %}Réclamations en Cours — kbadhapay{% endblock %}

{% block body %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-spinner mr-2 text-warning"></i>Réclamations en Cours
    </h1>
    <a href="{{ path('admin_reclamation_index') }}" class="btn btn-sm btn-secondary shadow-sm">
        <i class="fas fa-list fa-sm text-white-50 mr-1"></i>Toutes les réclamations
    </a>
</div>

<div class="card shadow mb-4 border-left-warning">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-warning">Réclamations nécessitant une réponse</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="thead-light">
                    <tr>
                        <th>ID</th>
                        <th>Sujet</th>
                        <th>Citoyen (CIN)</th>
                        <th>Date de dépôt</th>
                        <th>Ancienneté</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for r in reclamations %}
                    <tr>
                        <td>#{{ r.id }}</td>
                        <td class="font-weight-bold text-dark">{{ r.sujet|default('Réclamation #' ~ r.id) }}</td>
                        <td>{{ r.user ? r.user.cin : '—' }}</td>
                        <td class="small">{{ r.dateSoumission ? r.dateSoumission|date('d/m/Y H:i') : '—' }}</td>
                        <td>
                            {% set jours = date(r.dateSoumission).diff(date('now')).days %}
                            {% if jours > 7 %}
                                <span class="badge badge-danger">{{ jours }} jours</span>
                            {% elseif jours > 3 %}
                                <span class="badge badge-warning text-dark">{{ jours }} jours</span>
                            {% else %}
                                <span class="badge badge-success">{{ jours }} jours</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <a href="{{ path('admin_reclamation_show', {'id': r.id}) }}" class="btn btn-primary btn-sm">
                                <i class="fas fa-reply mr-1"></i>Répondre
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="fas fa-check-double fa-2x mb-3 d-block text-success"></i>
                            Toutes les réclamations ont été traitées !
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

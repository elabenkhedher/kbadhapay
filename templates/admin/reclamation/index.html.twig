{% extends 'base.html.twig' %}

{% block title %}Gestion des Réclamations — kbadhapay{% endblock %}

{% block body %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-envelope mr-2 text-danger"></i>Gestion des Réclamations
    </h1>
    <a href="{{ path('admin_reclamation_en_cours') }}" class="btn btn-sm btn-warning shadow-sm">
        <i class="fas fa-spinner fa-sm text-white-50 mr-1"></i>Réclamations en cours
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Liste de toutes les réclamations</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="thead-light">
                    <tr>
                        <th>ID</th>
                        <th>Sujet</th>
                        <th>Citoyen (CIN)</th>
                        <th>Date de dépôt</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for r in reclamations %}
                    <tr>
                        <td>#{{ r.id }}</td>
                        <td class="font-weight-bold">{{ r.sujet|default('Réclamation #' ~ r.id) }}</td>
                        <td>{{ r.user ? r.user.cin : '—' }}</td>
                        <td class="small">{{ r.dateSoumission ? r.dateSoumission|date('d/m/Y H:i') : '—' }}</td>
                        <td>
                            {% if r.statut == 'resolue' or r.statut == 'résolue' %}
                                <span class="badge badge-success">Résolue</span>
                            {% elseif r.statut == 'en_cours' %}
                                <span class="badge badge-warning text-dark">En cours</span>
                            {% elseif r.statut == 'rejetee' or r.statut == 'rejetée' %}
                                <span class="badge badge-danger">Rejetée</span>
                            {% else %}
                                <span class="badge badge-secondary">{{ r.statut }}</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <a href="{{ path('admin_reclamation_show', {'id': r.id}) }}" class="btn btn-info btn-circle btn-sm" title="Voir les détails">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Aucune réclamation trouvée.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

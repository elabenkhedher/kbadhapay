{% extends 'base.html.twig' %}
{% block title %}Modifier — {{ user.userIdentifier }}{% endblock %}

{% block body %}

{% for msg in app.flashes('success') %}<div class="alert alert-success alert-dismissible fade show"><i class="fas fa-check-circle mr-2"></i>{{ msg }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>{% endfor %}
{% for msg in app.flashes('danger') %}<div class="alert alert-danger alert-dismissible fade show"><i class="fas fa-exclamation-circle mr-2"></i>{{ msg }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>{% endfor %}

<div class="d-sm-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-user-edit mr-2 text-warning"></i>Modifier —
        <span class="text-primary">{{ user.userIdentifier }}</span>
    </h1>
    <a href="{{ path('admin_user_index') }}" class="btn btn-secondary btn-sm">
        <i class="fas fa-arrow-left mr-1"></i>Retour à la liste
    </a>
</div>

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-white shadow-sm small">
        <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}"><i class="fas fa-home mr-1"></i>Accueil</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin_user_index') }}">Utilisateurs</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin_user_show', {id: user.id}) }}">{{ user.userIdentifier }}</a></li>
        <li class="breadcrumb-item active">Modifier</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-xl-7 col-lg-9">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-warning">
                    <i class="fas fa-user-edit mr-2"></i>Modifier l'utilisateur — #{{ user.id }}
                </h6>
            </div>
            <div class="card-body">
                {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

                    {# CIN #}
                    <div class="form-group">
                        {{ form_label(form.cin, null, {label_attr: {class: 'font-weight-bold'}}) }}
                        {{ form_widget(form.cin, {attr: {class: 'form-control', maxlength: 8, pattern: '[0-9]{8}', inputmode: 'numeric'}}) }}
                        {{ form_errors(form.cin) }}
                    </div>

                    {# Num Tel #}
                    <div class="form-group">
                        {{ form_label(form.telephone, null, {label_attr: {class: 'font-weight-bold'}}) }}
                        {{ form_widget(form.telephone, {attr: {class: 'form-control', maxlength: 8, pattern: '[0-9]{8}', placeholder: '8 chiffres', inputmode: 'numeric'}}) }}
                        <small class="text-muted">Le Num Tel sera utilisé pour envoyer les messages.</small>
                        {{ form_errors(form.telephone) }}
                    </div>

                    {# Mot de passe optionnel en édition #}
                    <div class="form-group">
                        {{ form_label(form.plainPassword, null, {label_attr: {class: 'font-weight-bold'}}) }}
                        {{ form_widget(form.plainPassword, {attr: {class: 'form-control'}}) }}
                        <small class="text-muted">
                            <i class="fas fa-info-circle mr-1"></i>
                            Laisser vide pour conserver le mot de passe actuel.
                        </small>
                        {{ form_errors(form.plainPassword) }}
                    </div>

                    {# Rôles #}
                    <div class="form-group">
                        {{ form_label(form.roles, null, {label_attr: {class: 'font-weight-bold d-block mb-2'}}) }}
                        <div class="border rounded p-3 bg-light">
                            {% for choice in form.roles %}
                                <div class="custom-control custom-checkbox mb-1">
                                    {{ form_widget(choice, {attr: {class: 'custom-control-input'}}) }}
                                    {{ form_label(choice, null, {label_attr: {class: 'custom-control-label'}}) }}
                                </div>
                            {% endfor %}
                        </div>
                        {{ form_errors(form.roles) }}
                    </div>

                    <hr class="my-4">
                    <div class="d-flex justify-content-end">
                        <a href="{{ path('admin_user_show', {id: user.id}) }}" class="btn btn-secondary mr-2">
                            <i class="fas fa-times mr-1"></i>Annuler
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-save mr-1"></i>Enregistrer les modifications
                        </button>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

{% endblock %}

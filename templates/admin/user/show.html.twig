{% extends 'base.html.twig' %}
{% block title %}Profil — {{ user.userIdentifier }}{% endblock %}

{% block body %}

{% for msg in app.flashes('success') %}<div class="alert alert-success alert-dismissible fade show"><i class="fas fa-check-circle mr-2"></i>{{ msg }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>{% endfor %}
{% for msg in app.flashes('danger') %}<div class="alert alert-danger alert-dismissible fade show"><i class="fas fa-exclamation-circle mr-2"></i>{{ msg }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>{% endfor %}

<div class="d-sm-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-user-circle mr-2 text-primary"></i>Profil — {{ user.userIdentifier }}
    </h1>
    <div>
        <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn btn-warning btn-sm mr-2">
            <i class="fas fa-edit mr-1"></i>Modifier
        </a>
        <a href="{{ path('admin_user_index') }}" class="btn btn-secondary btn-sm">
            <i class="fas fa-arrow-left mr-1"></i>Retour à la liste
        </a>
    </div>
</div>

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-white shadow-sm small">
        <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}"><i class="fas fa-home mr-1"></i>Accueil</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin_user_index') }}">Utilisateurs</a></li>
        <li class="breadcrumb-item active">{{ user.userIdentifier }}</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-10">

        {# ── Card profil ── #}
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-id-card mr-2"></i>Informations du compte
                </h6>
                <span class="text-muted small">ID #{{ user.id }}</span>
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless table-striped mb-0">
                    <tbody>
                        {# CIN (identifiant de connexion) #}
                        <tr>
                            <th style="width:35%" class="pl-4 text-gray-600">
                                <i class="fas fa-id-badge mr-2 text-muted"></i>Numéro CIN
                            </th>
                            <td class="font-weight-bold text-primary pr-4" style="font-size:1.05rem;letter-spacing:1px;">
                                {{ user.cin }}
                            </td>
                        </tr>

                        {# Rôles #}
                        <tr>
                            <th class="pl-4 text-gray-600">
                                <i class="fas fa-shield-alt mr-2 text-muted"></i>Rôle(s)
                            </th>
                            <td class="pr-4">
                                {% for role in user.roles %}
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span class="badge badge-danger px-2 py-1 mr-1"><i class="fas fa-shield-alt mr-1"></i>Admin</span>
                                    {% elseif role == 'ROLE_KBADHA' %}
                                        <span class="badge badge-primary px-2 py-1 mr-1"><i class="fas fa-cash-register mr-1"></i>Agent Kbadha</span>
                                    {% elseif role == 'ROLE_POLICE' %}
                                        <span class="badge badge-warning text-dark px-2 py-1 mr-1"><i class="fas fa-user-shield mr-1"></i>Agent Police</span>
                                    {% elseif role == 'ROLE_CITOYEN' %}
                                        <span class="badge badge-success px-2 py-1 mr-1"><i class="fas fa-user mr-1"></i>Citoyen</span>
                                    {% elseif role != 'ROLE_USER' %}
                                        <span class="badge badge-secondary px-2 py-1 mr-1">{{ role }}</span>
                                    {% endif %}
                                {% endfor %}
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-white d-flex justify-content-end">
                <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn btn-warning mr-2">
                    <i class="fas fa-edit mr-1"></i>Modifier
                </a>
                <a href="{{ path('admin_user_index') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left mr-1"></i>Retour à la liste
                </a>
            </div>
        </div>

        {# ── Zone de danger ── #}
        {% if user.id != app.user.id %}
            <div class="card shadow mb-4 border-left-danger">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-danger">
                        <i class="fas fa-exclamation-triangle mr-2"></i>Zone de danger
                    </h6>
                </div>
                <div class="card-body d-flex align-items-center justify-content-between">
                    <p class="mb-0 text-gray-600">Suppression <strong>irréversible</strong> de cet utilisateur.</p>
                    <form action="{{ path('admin_user_delete', {id: user.id}) }}"
                          method="POST"
                          onsubmit="return confirm('Confirmer la suppression de l\'utilisateur CIN {{ user.cin }} ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                        <button class="btn btn-danger btn-sm ml-3">
                            <i class="fas fa-trash mr-1"></i>Supprimer
                        </button>
                    </form>
                </div>
            </div>
        {% else %}
            <div class="alert alert-warning">
                <i class="fas fa-info-circle mr-2"></i>
                Vous consultez <strong>votre propre compte</strong>. L'auto-suppression est désactivée.
            </div>
        {% endif %}

    </div>
</div>

{% endblock %}

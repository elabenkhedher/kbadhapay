{% extends 'base.html.twig' %}
{% block title %}Modifier la Taxe{% endblock %}

{% block body %}

{% for msg in app.flashes('success') %}<div class="alert alert-success alert-dismissible fade show"><i class="fas fa-check-circle mr-2"></i>{{ msg }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>{% endfor %}
{% for msg in app.flashes('danger') %}<div class="alert alert-danger alert-dismissible fade show"><i class="fas fa-exclamation-circle mr-2"></i>{{ msg }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>{% endfor %}

<div class="d-sm-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-edit mr-2 text-warning"></i>Modifier la Taxe :
        <span class="text-primary">{{ taxe.nomTaxe }}</span>
    </h1>
    <a href="{{ path('admin_taxe_index') }}" class="btn btn-secondary btn-sm">
        <i class="fas fa-arrow-left mr-1"></i>Retour à la liste
    </a>
</div>

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-white shadow-sm small">
        <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}"><i class="fas fa-home mr-1"></i>Accueil</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin_taxe_index') }}">Taxes</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin_taxe_show', {id: taxe.id}) }}">{{ taxe.nomTaxe }}</a></li>
        <li class="breadcrumb-item active">Modifier</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-10">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-warning">
                    <i class="fas fa-edit mr-2"></i>Modifier les informations — Taxe #{{ taxe.id }}
                </h6>
            </div>
            <div class="card-body">
                {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

                    <div class="form-group">
                        {{ form_label(form.nom_taxe, null, {label_attr: {class: 'font-weight-bold'}}) }}
                        {{ form_widget(form.nom_taxe, {attr: {class: 'form-control'}}) }}
                        {{ form_errors(form.nom_taxe) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.description, null, {label_attr: {class: 'font-weight-bold'}}) }}
                        {{ form_widget(form.description, {attr: {class: 'form-control', rows: 4}}) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.montant, null, {label_attr: {class: 'font-weight-bold'}}) }}
                        <div class="input-group">
                            {{ form_widget(form.montant, {attr: {class: 'form-control'}}) }}
                            <div class="input-group-append">
                                <span class="input-group-text font-weight-bold">DT</span>
                            </div>
                        </div>
                        {{ form_errors(form.montant) }}
                    </div>

                    <div class="form-group">
                        <div class="custom-control custom-switch">
                            {{ form_widget(form.actif, {attr: {class: 'custom-control-input'}}) }}
                            {{ form_label(form.actif, null, {label_attr: {class: 'custom-control-label font-weight-bold'}}) }}
                        </div>
                        {{ form_errors(form.actif) }}
                    </div>

                    <hr class="my-4">
                    <div class="d-flex justify-content-end">
                        <a href="{{ path('admin_taxe_show', {id: taxe.id}) }}" class="btn btn-secondary mr-2">
                            <i class="fas fa-times mr-1"></i>Annuler
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-save mr-1"></i>Enregistrer les modifications
                        </button>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}Liste des Taxes{% endblock %}

{% block body %}

{# ── Flash messages ─────────────────────────────────────────────── #}
{% for msg in app.flashes('success') %}<div class="alert alert-success alert-dismissible fade show shadow-sm"><i class="fas fa-check-circle mr-2"></i>{{ msg }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>{% endfor %}
{% for msg in app.flashes('danger') %}<div class="alert alert-danger alert-dismissible fade show shadow-sm"><i class="fas fa-exclamation-circle mr-2"></i>{{ msg }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>{% endfor %}

{# ── En-tête ─────────────────────────────────────────────────────── #}
<div class="d-sm-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-file-invoice-dollar mr-2 text-primary"></i>Liste des Taxes
    </h1>
    <a href="{{ path('admin_taxe_new') }}" class="btn btn-primary btn-sm shadow-sm">
        <i class="fas fa-plus fa-sm mr-1"></i>Ajouter une Taxe
    </a>
</div>

{# ── Fil d'ariane ─────────────────────────────────────────────────── #}
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-white shadow-sm small">
        <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}"><i class="fas fa-home mr-1"></i>Accueil</a></li>
        <li class="breadcrumb-item active">Taxes</li>
    </ol>
</nav>

{# ── Carte tableau ────────────────────────────────────────────────── #}
<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-table mr-2"></i>Toutes les taxes
            <span class="badge badge-primary ml-1">{{ taxes|length }}</span>
        </h6>
    </div>
    <div class="card-body">
        {% if taxes is empty %}
            <div class="alert alert-info mb-0">
                <i class="fas fa-info-circle mr-2"></i>Aucune taxe enregistrée.
                <a href="{{ path('admin_taxe_new') }}" class="font-weight-bold ml-2">Ajouter la première taxe →</a>
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover table-bordered" width="100%">
                    <thead class="thead-light">
                        <tr>
                            <th style="width:60px">#</th>
                            <th>Nom de la Taxe</th>
                            <th style="width:160px" class="text-right">Montant (DT)</th>
                            <th style="width:120px" class="text-center">Statut</th>
                            <th style="width:145px" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for taxe in taxes %}
                            <tr>
                                <td class="text-center text-muted">{{ taxe.id }}</td>
                                <td class="font-weight-bold">{{ taxe.nomTaxe }}</td>
                                <td class="text-right font-weight-bold">
                                    {{ taxe.montant|number_format(3, ',', ' ') }} DT
                                </td>
                                <td class="text-center">
                                    {% if taxe.isActif %}
                                        <span class="badge badge-success px-3 py-2"><i class="fas fa-check-circle mr-1"></i>Active</span>
                                    {% else %}
                                        <span class="badge badge-secondary px-3 py-2"><i class="fas fa-archive mr-1"></i>Archivée</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    <a href="{{ path('admin_taxe_show', {id: taxe.id}) }}"
                                       class="btn btn-info btn-sm" title="Consulter"><i class="fas fa-eye"></i></a>
                                    <a href="{{ path('admin_taxe_edit', {id: taxe.id}) }}"
                                       class="btn btn-warning btn-sm" title="Modifier"><i class="fas fa-edit"></i></a>
                                    <form action="{{ path('admin_taxe_delete', {id: taxe.id}) }}"
                                          method="POST" class="d-inline"
                                          onsubmit="return confirm('Confirmer la suppression de la taxe « {{ taxe.nomTaxe }} » ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ taxe.id) }}">
                                        <button class="btn btn-danger btn-sm" title="Supprimer"><i class="fas fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>

{% endblock %}

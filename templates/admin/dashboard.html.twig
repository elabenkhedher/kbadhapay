{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord — kbadhapay{% endblock %}

{% block body %}

{# ════════════════════════════════════════════════════════════════════
   EN-TÊTE DE PAGE + FIL D'ARIANE
════════════════════════════════════════════════════════════════════ #}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-tachometer-alt mr-2 text-primary"></i>
        Tableau de Bord Administrateur
    </h1>
    <ol class="breadcrumb mb-0 bg-transparent">
        <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}">Accueil</a></li>
        <li class="breadcrumb-item active">Dashboard</li>
    </ol>
</div>
<div class="d-none d-sm-flex align-items-center mb-4">
    <div class="d-none d-sm-flex align-items-center">
        <span class="text-muted small mr-3">
            <i class="fas fa-calendar-alt mr-1"></i>
            {{ "now"|date("d/m/Y") }}
        </span>
        <a href="{{ path('admin_reporting_download') }}" class="btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-download fa-sm text-white-50 mr-1"></i>Rapport
        </a>
    </div>
</div>


{# ════════════════════════════════════════════════════════════════════
   SECTION 2 — 4 CARTES KPI
════════════════════════════════════════════════════════════════════ #}
<div class="row mb-4">

    {# ── KPI 1 : Taxes Actives (primary) ── #}
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Taxes Actives
                        </div>
                        <div class="mb-0 text-gray-800">
                            <span class="h2 font-weight-bold">{{ nbTaxes ?? 0 }}</span>
                        </div>
                        <div class="progress progress-sm mt-2">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-landmark fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 py-1 text-center">
                <a href="{{ path('admin_taxe_index') }}" class="text-primary small font-weight-bold">
                    Voir les taxes <i class="fas fa-arrow-right fa-xs ml-1"></i>
                </a>
            </div>
        </div>
    </div>

    {# ── KPI 2 : Infractions en Attente (warning) ── #}
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            Infractions en Attente
                        </div>
                        <div class="mb-0 text-gray-800">
                            <span class="h2 font-weight-bold">{{ nbInfractions ?? 0 }}</span>
                        </div>
                        <div class="progress progress-sm mt-2">
                            <div class="progress-bar bg-warning" role="progressbar" style="width: 50%" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-exclamation-triangle fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 py-1 text-center">
                <a href="{{ path('admin_infraction_index') }}" class="text-warning small font-weight-bold">
                    Voir les infractions <i class="fas fa-arrow-right fa-xs ml-1"></i>
                </a>
            </div>
        </div>
    </div>

    {# ── KPI 3 : Paiements ce Mois (success) ── #}
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            Paiements ce Mois
                        </div>
                        <div class="mb-0 text-gray-800">
                            <span class="h2 font-weight-bold">{{ nbPaiements ?? 0 }}</span>
                        </div>
                        <div class="progress progress-sm mt-2">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 80%" aria-valuenow="80" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-credit-card fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 py-1 text-center">
                <a href="{{ path('admin_paiement_index') }}" class="text-success small font-weight-bold">
                    Voir les paiements <i class="fas fa-arrow-right fa-xs ml-1"></i>
                </a>
            </div>
        </div>
    </div>

    {# ── KPI 4 : Réclamations en Cours (danger) ── #}
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-info shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                            Réclamations en Cours
                        </div>
                        <div class="mb-0 text-gray-800">
                            <span class="h2 font-weight-bold">{{ nbReclamations ?? 0 }}</span>
                        </div>
                        <div class="progress progress-sm mt-2">
                            <div class="progress-bar bg-info" role="progressbar" style="width: 30%" aria-valuenow="30" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-envelope fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 py-1 text-center">
                <a href="{{ path('admin_reclamation_index') }}" class="text-info small font-weight-bold">
                    Voir les réclamations <i class="fas fa-arrow-right fa-xs ml-1"></i>
                </a>
            </div>
        </div>
    </div>

</div>{# ── FIN CARTES KPI ── #}


{# ════════════════════════════════════════════════════════════════════
   SECTION 3 — TABLEAU : 5 DERNIERS PAIEMENTS
════════════════════════════════════════════════════════════════════ #}
<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-history mr-2"></i>5 Derniers Paiements
        </h6>
        <a href="{{ path('admin_paiement_index') }}" class="btn btn-sm btn-outline-primary">
            Voir tous <i class="fas fa-arrow-right fa-xs ml-1"></i>
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover table-sm" id="tableDerniersPaiements">
                <thead class="thead-dark">
                    <tr>
                        <th class="text-center">Référence</th>
                        <th>Citoyen (CIN)</th>
                        <th class="text-right">Montant</th>
                        <th class="text-center">Mode</th>
                        <th class="text-center">Statut</th>
                        <th>Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% if derniersPaiements is defined and derniersPaiements is not empty %}
                        {% for p in derniersPaiements %}
                            <tr>
                                {# Référence #}
                                <td class="text-center">
                                    <span class="font-weight-bold text-primary">
                                        #{{ '%05d'|format(p.id) }}
                                    </span>
                                </td>

                                {# Citoyen CIN #}
                                <td>
                                    {{ p.user is defined and p.user ? p.user.cin : '—' }}
                                </td>

                                {# Montant #}
                                <td class="text-right font-weight-bold">
                                    {% if p.taxe is defined and p.taxe %}
                                        {{ p.taxe.montant|number_format(3, ',', ' ') }} DT
                                    {% elseif p.infraction is defined and p.infraction %}
                                        {{ p.infraction.montantAmende|number_format(3, ',', ' ') }} DT
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>

                                {# Mode de paiement #}
                                <td class="text-center">
                                    {% if p.modePaiement is defined or p.mode is defined %}
                                        {% set mode = p.modePaiement ?? p.mode %}
                                        {% if mode == 'en_ligne' or mode == 'enligne' %}
                                            <span class="badge badge-primary px-3 py-1">En ligne</span>
                                        {% elseif mode == 'especes' %}
                                            <span class="badge badge-secondary px-3 py-1">Espèces</span>
                                        {% elseif mode == 'cheque' %}
                                            <span class="badge badge-dark px-3 py-1">Chèque</span>
                                        {% else %}
                                            <span class="badge badge-light border px-3 py-1">{{ mode }}</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>

                                {# Statut #}
                                <td class="text-center">
                                    {% if p.statut == 'payé' or p.statut == 'paye' %}
                                        <span class="badge badge-success px-3 py-1">Payé</span>
                                    {% elseif p.statut == 'en_attente' or p.statut == 'en attente' %}
                                        <span class="badge badge-warning text-dark px-3 py-1">En attente</span>
                                    {% elseif p.statut == 'en_retard' or p.statut == 'en retard' %}
                                        <span class="badge badge-danger px-3 py-1">En retard</span>
                                    {% else %}
                                        <span class="badge badge-secondary px-3 py-1">{{ p.statut }}</span>
                                    {% endif %}
                                </td>

                                {# Date de soumission #}
                                <td class="text-muted small">
                                    {{ p.dateSoumission ? p.dateSoumission|date('d/m/Y') : '—' }}
                                </td>

                                <td class="text-center">
                                    <a href="{{ path('admin_paiement_show', {'id': p.id}) }}" class="btn btn-info btn-sm mr-1" title="Consulter">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="fas fa-inbox fa-2x mb-2 d-block text-gray-300"></i>
                                Aucun paiement enregistré.
                            </td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
        <div class="text-right mt-2">
            <a href="{{ path('admin_paiement_index') }}" class="btn btn-link btn-sm text-primary">
                <i class="fas fa-list fa-xs mr-1"></i>Voir tous les paiements
            </a>
        </div>
    </div>
</div>


{# ════════════════════════════════════════════════════════════════════
   SECTION 4 — 2 COLONNES : Infractions & Réclamations récentes
════════════════════════════════════════════════════════════════════ #}
<div class="row">

    {# ── Colonne gauche : 5 Dernières Infractions ── #}
    <div class="col-lg-6">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-warning">
                    <i class="fas fa-exclamation-triangle mr-2"></i>5 Dernières Infractions
                </h6>
                <a href="{{ path('admin_infraction_index') }}" class="btn btn-sm btn-outline-warning">
                    Voir tout <i class="fas fa-arrow-right fa-xs ml-1"></i>
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover table-sm mb-0" id="tableDernieresInfractions">
                        <thead class="thead-dark">
                            <tr>
                                <th>CIN Citoyen</th>
                                <th>Lieu</th>
                                <th>Plaque</th>
                                <th class="text-right">Montant</th>
                                <th class="text-center">Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% if dernieresInfractions is defined and dernieresInfractions is not empty %}
                                {% for i in dernieresInfractions %}
                                    <tr>
                                        <td>
                                            {{ i.user is defined and i.user ? i.user.cin : '—' }}
                                        </td>
                                        <td class="small text-muted">{{ i.lieu ?? '—' }}</td>
                                        <td>
                                            <span class="badge badge-light border">
                                                {{ i.plaqueImmat ?? '—' }}
                                            </span>
                                        </td>
                                        <td class="text-right font-weight-bold">
                                            {{ i.montantAmende is defined ? i.montantAmende|number_format(3, ',', ' ') ~ ' DT' : '—' }}
                                        </td>
                                        <td class="text-center">
                                            {% if i.statut == 'payée' or i.statut == 'payee' or i.statut == 'paye' %}
                                                <span class="badge badge-success px-3 py-1">Payé</span>
                                            {% elseif i.statut == 'a_payer' or i.statut == 'en_attente' or i.statut == 'en attente' %}
                                                <span class="badge badge-warning text-dark px-3 py-1">En attente</span>
                                            {% elseif i.statut == 'contestée' or i.statut == 'contestee' %}
                                                <span class="badge badge-danger px-3 py-1">Contesté</span>
                                            {% else %}
                                                <span class="badge badge-secondary px-3 py-1">{{ i.statut }}</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% else %}
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-3">
                                        <i class="fas fa-inbox text-gray-300 d-block mb-1"></i>
                                        Aucune infraction récente.
                                    </td>
                                </tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    {# ── Colonne droite : 5 Dernières Réclamations ── #}
    <div class="col-lg-6">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-danger">
                    <i class="fas fa-envelope mr-2"></i>5 Dernières Réclamations
                </h6>
                <a href="{{ path('admin_reclamation_index') }}" class="btn btn-sm btn-outline-danger">
                    Voir tout <i class="fas fa-arrow-right fa-xs ml-1"></i>
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover table-sm mb-0" id="tableDernieresReclamations">
                        <thead class="thead-dark">
                            <tr>
                                <th>Sujet</th>
                                <th>Citoyen (CIN)</th>
                                <th>Date</th>
                                <th class="text-center">Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% if dernieresReclamations is defined and dernieresReclamations is not empty %}
                                {% for r in dernieresReclamations %}
                                    <tr>
                                        <td>
                                            {% set displaySujet = r.sujet|default('Réclamation #' ~ r.id) %}
                                            <a href="{{ path('admin_reclamation_show', {'id': r.id}) }}"
                                               class="text-dark font-weight-bold"
                                               title="{{ displaySujet }}">
                                                {{ displaySujet|length > 30 ? displaySujet|slice(0, 30) ~ '…' : displaySujet }}
                                            </a>
                                        </td>
                                        <td>
                                            {{ r.user is defined and r.user ? r.user.cin : '—' }}
                                        </td>
                                        <td class="text-muted small">
                                            {{ r.dateSoumission ? r.dateSoumission|date('d/m/Y') : '—' }}
                                        </td>
                                        <td class="text-center">
                                            {% if r.statut == 'résolue' or r.statut == 'resolue' %}
                                                <span class="badge badge-success px-3 py-1">Résolu</span>
                                            {% elseif r.statut == 'en_cours' or r.statut == 'en cours' %}
                                                <span class="badge badge-info px-3 py-1">En cours</span>
                                            {% elseif r.statut == 'en_attente' or r.statut == 'en attente' %}
                                                <span class="badge badge-warning text-dark px-3 py-1">En attente</span>
                                            {% elseif r.statut == 'rejetée' or r.statut == 'rejetee' %}
                                                <span class="badge badge-danger px-3 py-1">Rejeté</span>
                                            {% else %}
                                                <span class="badge badge-light border px-3 py-1">{{ r.statut }}</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">
                                        <i class="fas fa-inbox text-gray-300 d-block mb-1"></i>
                                        Aucune réclamation récente.
                                    </td>
                                </tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>{# ── FIN SECTION 4 ── #}

{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Gestion des Paiements — kbadhapay{% endblock %}

{% block body %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-credit-card mr-2 text-primary"></i>Gestion des Paiements
    </h1>
    <a href="{{ path('admin_paiement_en_attente') }}" class="btn btn-sm btn-warning shadow-sm">
        <i class="fas fa-clock fa-sm text-white-50 mr-1"></i>Paiements en attente
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Liste de tous les paiements</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="thead-light">
                    <tr>
                        <th>Réf</th>
                        <th>Citoyen (CIN)</th>
                        <th>Sujet</th>
                        <th>Montant</th>
                        <th>Mode</th>
                        <th>Statut</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for p in paiements %}
                    <tr>
                        <td>#{{ '%05d'|format(p.id) }}</td>
                        <td>{{ p.user ? p.user.cin : '—' }}</td>
                        <td class="small">{{ p.sujet }}</td>
                        <td class="font-weight-bold">
                            {{ p.montant|number_format(3, ',', ' ') }} DT
                        </td>
                        <td>
                            {% if p.modePaiement == 'en_ligne' %}
                                <span class="badge badge-primary">En ligne</span>
                            {% elseif p.modePaiement == 'especes' %}
                                <span class="badge badge-secondary">Espèces</span>
                            {% elseif p.modePaiement == 'cheque' %}
                                <span class="badge badge-info">Chèque</span>
                            {% else %}
                                <span class="badge badge-light border">{{ p.modePaiement }}</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if p.statut == 'paye' or p.statut == 'payé' %}
                                <span class="badge badge-success">Payé</span>
                            {% elseif p.statut == 'en_attente' %}
                                <span class="badge badge-warning text-dark">En attente</span>
                            {% else %}
                                <span class="badge badge-danger">{{ p.statut }}</span>
                            {% endif %}
                        </td>
                        <td class="small">
                            {{ p.dateSoumission ? p.dateSoumission|date('d/m/Y') : '—' }}
                        </td>
                        <td class="text-center">
                            <a href="{{ path('admin_paiement_show', {'id': p.id}) }}" class="btn btn-info btn-circle btn-sm" title="Détails">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">Aucun paiement trouvé.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Paiements en Attente — kbadhapay{% endblock %}

{% block body %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-clock mr-2 text-warning"></i>Paiements en Attente
    </h1>
    <a href="{{ path('admin_paiement_index') }}" class="btn btn-sm btn-secondary shadow-sm">
        <i class="fas fa-list fa-sm text-white-50 mr-1"></i>Tous les paiements
    </a>
</div>

<div class="card shadow mb-4 border-bottom-warning">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-warning">Paiements nécessitant une validation ou action</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="thead-light">
                    <tr>
                        <th>ID</th>
                        <th>Type</th>
                        <th>Citoyen (CIN)</th>
                        <th>Montant</th>
                    </tr>
                </thead>
                <tbody>
                {% for p in paiements %}
                    <tr>
                        <td>#{{ '%05d'|format(p.id) }}</td>
                        <td> {{ p.getTypeInfraction() }} </td>
                        <td>{{ p.user ? p.user.cin : '—' }}</td>
                        <td class="font-weight-bold"> {{ p.getMontantAmende() }} DT</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="fas fa-check-circle fa-2x mb-3 d-block text-success"></i>
                            Aucun paiement en attente.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
